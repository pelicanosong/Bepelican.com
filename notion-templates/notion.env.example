# Copiá este archivo a la raíz del proyecto como .env.notion
# cp notion-templates/notion.env.example .env.notion

# 1. Crear integration: https://www.notion.so/my-integrations
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 2. ID de la página donde quieras las 3 bases (de la URL de Notion)
#    Ejemplo URL: https://www.notion.so/mi-workspace/BePelican-abc123def456...
#    El ID son los 32 caracteres finales (con o sin guiones)
NOTION_PARENT_PAGE_ID=357b5f0e3484810d8d8be07d4fbd2aa1
