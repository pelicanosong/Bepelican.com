{
  "name": "BePelican Notion → Supabase Sync",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "minutes",
              "minutesInterval": 30
            }
          ]
        }
      },
      "id": "schedule-trigger",
      "name": "Cada 30 minutos",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [0, 0]
    },
    {
      "parameters": {
        "command": "cd {{ $env.BEPELICAN_REPO_PATH || '/root/bepelican-ecommerce' }} && node scripts/sync-notion-to-supabase.mjs"
      },
      "id": "run-sync",
      "name": "Sync Notion → Supabase",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [220, 0]
    },
    {
      "parameters": {},
      "id": "manual-trigger",
      "name": "Manual (probar ahora)",
      "type": "n8n-nodes-base.manualTrigger",
      "typeVersion": 1,
      "position": [0, 200]
    }
  ],
  "connections": {
    "Cada 30 minutos": {
      "main": [[{ "node": "Sync Notion → Supabase", "type": "main", "index": 0 }]]
    },
    "Manual (probar ahora)": {
      "main": [[{ "node": "Sync Notion → Supabase", "type": "main", "index": 0 }]]
    }
  },
  "settings": {
    "executionOrder": "v1"
  },
  "meta": {
    "templateCredsSetupCompleted": false
  }
}
